# Copy this file to `.env` for local development: cp .env.example .env
# The .env file is gitignored and only loaded locally. On Azure, set these as
# real environment variables (App Service > Configuration) instead.

# Local dev: enable debug. Production must leave this False (omit or set 0).
DEBUG=1

# Required in production (DEBUG=0). Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=

# Required in production. Local falls back to db.sqlite3 if unset.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Comma-separated. Local dev auto-allows localhost/127.0.0.1 when DEBUG=1.
# ALLOWED_HOSTS=lmpm.azurewebsites.net

# Microsoft SSO (django-allauth). Reuse the same Entra tenant as OSED so staff
# sign in with the same Microsoft account; register a SEPARATE redirect URI
# (this app's /accounts/microsoft/login/callback/) in the app registration.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=organizations
